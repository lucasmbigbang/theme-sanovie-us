{% doc %}
  @prompt
    Crée une section réutilisable "Features Grid" avec :
    
    STRUCTURE :
    - Header : image de fond (uploadable), titre centré en texte blanc par-dessus
    - Grille 2x2 sur mobile, 1 ligne de 4 sur desktop
    - Chaque carte : fond blanc, coins arrondis, ombre légère
    
    CHAQUE CARTE :
    - Image rectangulaire en haut (ratio 4:3, bords arrondis en haut)
    - Titre en gras bleu navy (#1B2A4A), taille h3
    - Petit trait horizontal bleu (#1B2A4A) de 30px sous le titre
    - Paragraphe en gris (#666), taille 14-15px
    - Padding intérieur généreux (~20px)
    
    ÉDITABLE :
    - Tous les textes, images et couleurs modifiables depuis le customizer
    - Image de fond du header uploadable
    - Nombre de blocs ajustable (2 à 4)
    - Titre du header éditable
    
    La section doit ressembler à une fiche technique produit médicale/premium, sobre et rassurante., l'image du header de cette section n'est pas un background, c'est un image au dessus du titre, et on peut ajuster sa taille
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-features-grid__header-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-features-grid__header-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    text-align: center;
    margin-bottom: 20px;
  }

  .ai-features-grid__header-image-{{ ai_gen_id }} {
    width: {{ block.settings.header_image_width }}%;
    max-width: 100%;
    height: auto;
    display: inline-block;
  }

  .ai-features-grid__header-image-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.header_image_width }}%;
    max-width: 100%;
    height: auto;
    display: inline-block;
    background-color: #f4f4f4;
    border-radius: 8px;
  }

  .ai-features-grid__header-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-features-grid__header-title-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.header_title_color }};
    font-size: {{ block.settings.header_title_size }}px;
    font-weight: 700;
    margin: 0;
    padding: 0 20px;
  }

  .ai-features-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-features-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .ai-features-grid__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-features-grid__card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px {{ block.settings.card_border_radius }}px 0 0;
  }

  .ai-features-grid__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-features-grid__card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-features-grid__card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-features-grid__card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-features-grid__card-title-{{ ai_gen_id }} {
    color: {{ block.settings.card_title_color }};
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .ai-features-grid__card-divider-{{ ai_gen_id }} {
    width: 30px;
    height: 2px;
    background-color: {{ block.settings.card_divider_color }};
    margin: 0;
  }

  .ai-features-grid__card-text-{{ ai_gen_id }} {
    color: {{ block.settings.card_text_color }};
    font-size: {{ block.settings.card_text_size }}px;
    line-height: 1.6;
    margin: 0;
  }
{% endstyle %}

<features-grid-{{ ai_gen_id }} class="ai-features-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-features-grid__header-{{ ai_gen_id }}">
    {% if block.settings.header_image %}
      <div class="ai-features-grid__header-image-wrapper-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.header_image | image_url: width: 1200 }}"
          alt="{{ block.settings.header_image.alt | escape }}"
          class="ai-features-grid__header-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.header_image.width }}"
          height="{{ block.settings.header_image.height }}"
        >
      </div>
    {% else %}
      <div class="ai-features-grid__header-image-wrapper-{{ ai_gen_id }}">
        <div class="ai-features-grid__header-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      </div>
    {% endif %}

    {% if block.settings.header_title != blank %}
      <h2 class="ai-features-grid__header-title-{{ ai_gen_id }}">
        {{ block.settings.header_title }}
      </h2>
    {% endif %}
  </div>

  <div class="ai-features-grid__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign card_enabled_key = 'card_' | append: i | append: '_enabled'
        assign card_image_key = 'card_' | append: i | append: '_image'
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_text_key = 'card_' | append: i | append: '_text'

        assign card_enabled = block.settings[card_enabled_key]
        assign card_image = block.settings[card_image_key]
        assign card_title = block.settings[card_title_key]
        assign card_text = block.settings[card_text_key]
      %}

      {% if card_enabled %}
        <div class="ai-features-grid__card-{{ ai_gen_id }}">
          <div class="ai-features-grid__card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 400 }}"
                alt="{{ card_image.alt | escape }}"
                class="ai-features-grid__card-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
              >
            {% else %}
              <div class="ai-features-grid__card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-features-grid__card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-features-grid__card-title-{{ ai_gen_id }}">
                {{ card_title }}
              </h3>
            {% endif %}

            <div class="ai-features-grid__card-divider-{{ ai_gen_id }}"></div>

            {% if card_text != blank %}
              <p class="ai-features-grid__card-text-{{ ai_gen_id }}">
                {{ card_text }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</features-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturesGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('features-grid-{{ ai_gen_id }}', FeaturesGrid{{ ai_gen_id }});
  })();
</script>

