{% doc %}
  @prompt
    Créer une section “Ce que disent les experts” avec un titre centré, puis une carte blanche arrondie contenant la photo d’une experte, une citation rassurante, son nom en couleur accent et sa fonction en texte secondaire. Design premium, minimal, orienté crédibilité et réassurance.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-expert-testimonial-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-expert-testimonial__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-expert-testimonial__title-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-expert-testimonial__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-expert-testimonial__image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-expert-testimonial__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-expert-testimonial__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-expert-testimonial__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-expert-testimonial__quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ block.settings.quote_color }};
    margin: 0;
    font-style: italic;
  }

  .ai-expert-testimonial__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.accent_color }};
    margin: 0;
  }

  .ai-expert-testimonial__role-{{ ai_gen_id }} {
    font-size: {{ block.settings.role_size }}px;
    color: {{ block.settings.role_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-expert-testimonial-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-expert-testimonial__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.title_spacing | times: 0.7 }}px;
    }

    .ai-expert-testimonial__card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-expert-testimonial__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }

    .ai-expert-testimonial__quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_size | times: 0.9 }}px;
    }

    .ai-expert-testimonial__name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_size | times: 0.9 }}px;
    }

    .ai-expert-testimonial__role-{{ ai_gen_id }} {
      font-size: {{ block.settings.role_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-expert-testimonial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-expert-testimonial__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-expert-testimonial__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-expert-testimonial__card-{{ ai_gen_id }}">
      <div class="ai-expert-testimonial__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.expert_image %}
          <img
            src="{{ block.settings.expert_image | image_url: width: 400 }}"
            alt="{{ block.settings.expert_name | escape }}"
            class="ai-expert-testimonial__image-{{ ai_gen_id }}"
            loading="lazy"
            width="400"
            height="400"
          >
        {% else %}
          <div class="ai-expert-testimonial__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if block.settings.quote != blank %}
        <p class="ai-expert-testimonial__quote-{{ ai_gen_id }}">{{ block.settings.quote }}</p>
      {% endif %}

      {% if block.settings.expert_name != blank %}
        <p class="ai-expert-testimonial__name-{{ ai_gen_id }}">{{ block.settings.expert_name }}</p>
      {% endif %}

      {% if block.settings.expert_role != blank %}
        <p class="ai-expert-testimonial__role-{{ ai_gen_id }}">{{ block.settings.expert_role }}</p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Avis d'expert",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Titre"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titre de la section",
      "default": "Ce que disent les experts"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille du titre",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Espacement sous le titre",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Expert"
    },
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Photo de l'expert"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Taille de la photo",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Citation",
      "default": "Ce produit représente une avancée significative dans le domaine. Je le recommande vivement à mes patients."
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Taille de la citation",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Couleur de la citation",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "expert_name",
      "label": "Nom de l'expert",
      "default": "Dr. Marie Dupont"
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Taille du nom",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "text",
      "id": "expert_role",
      "label": "Fonction de l'expert",
      "default": "Médecin spécialiste, 15 ans d'expérience"
    },
    {
      "type": "range",
      "id": "role_size",
      "label": "Taille de la fonction",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "role_color",
      "label": "Couleur de la fonction",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Carte"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fond de la carte",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arrondi de la carte",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Espacement interne",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Espacement entre éléments",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Ombre"
    },
    {
      "type": "range",
      "id": "shadow_x",
      "label": "Position horizontale",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_y",
      "label": "Position verticale",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Flou de l'ombre",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "shadow_color",
      "label": "Couleur de l'ombre",
      "default": "#00000010"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur accent (nom)",
      "default": "#FFD815"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond de la section",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximale",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Espacement vertical",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Avis d'expert"
    }
  ]
}
{% endschema %}