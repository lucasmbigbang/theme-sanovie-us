        "accordion_awyjgt": {
          "type": "accordion",
          "name": "t:names.accordion",
          "settings": {
            "icon": "caret",
            "dividers": true,
            "type_preset": "h5",
            "inherit_color_scheme": true,
            "color_scheme": "",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "accordion_row_7fDxeK": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Can I wash the knee brace?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_CYQGxB": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes! It can be machine washed on a delicate cycle, but hand washing is recommended to extend its lifespan. Let it air dry, avoid the dryer and high temperatures.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_CYQGxB"
              ]
            },
            "accordion_row_Gjxndk": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Can I return my order if I'm not satisfied?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_YrEnLh": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Absolutely. Sanovia offers a 60-day satisfaction guarantee or your money back. If the Stabilix Pro™ doesn't suit you, you can return it for a full refund. Returns are easily processed through our online portal — a prepaid return label will be provided.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_YrEnLh"
              ]
            },
            "accordion_row_zYkmah": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Will the knee brace fit me?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_y3WDQH": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Yes! The Stabilix Pro™ is equipped with SLS™ quick-adjust technology, allowing precise and secure fitting. It's available in multiple sizes (M, L, XL, XXL) to fit all body types.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_y3WDQH"
              ]
            },
            "accordion_row_XUBMtH": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "How does it improve athletic performance?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_RPbArp": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>By keeping muscles warm and reducing fatigue, the Stabilix Pro™ helps prevent injuries, improve endurance and accelerate recovery. The compression and targeted support reduce stress on the knee during high-impact activities: running, jumping, weight training.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_RPbArp"
              ]
            },
            "accordion_row_y7h7wp": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Does it slip or roll during movement?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_gYTJn9": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>No. The anti-slip silicone band keeps the brace in place, even during intense workouts. Unlike classic knee braces that require constant readjustment, the Stabilix Pro™ stays put without friction or discomfort.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "color": "var(--color-foreground)",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_gYTJn9"
              ]
            },
            "accordion_row_X7kCxt": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Where is the product shipped from? What are the shipping costs?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_LVEUEG": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>We ship from our US warehouse. Shipping is free on orders over $65. In case of local stock shortage, your order will be shipped from the nearest international warehouse to your address.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
